# Archivos que NO se incluyen en el bundle a shinyapps.io
# https://docs.posit.co/connect/user/troubleshooting/#deployment-ignored-files

# CI / Git
.github/
.gitignore
.new_periods.txt

# Scripts de test y desarrollo (no usados por la app productiva)
app_test.R
ETL/TEST_app.R
ETL/data_generator.R
ETL/data_viz.R
ETL/03-update_data.R

# Outputs intermedios del data_generator legacy
data_output/paneles_eph_Desocupado.csv
data_output/paneles_eph_Inactivo.csv
data_output/paneles_eph_Ocupado.csv

# Backups del parquet del microdato. ~70 MB innecesarios en el bundle.
data_raw/df_eph.parquet.bak
data_raw/df_eph.parquet.bak2

# Microdato completo (~40 MB). En runtime ya no se usa: la app levanta
# data_output/panel_runtime.parquet (~21 MB) que tiene los paneles ya
# armados para todos los dúos válidos. El microdato se mantiene en disco
# (versionado en git LFS) para poder regenerar el panel runtime con
# ETL/09-build_paneles_runtime.R cuando hay nuevos trimestres.
data_raw/df_eph.parquet

# Screenshots de revisiones UX con Playwright (no son parte de la app)
.playwright-mcp/

# Corpus de documentación EPH (PDFs + textos extraídos). No se usa en
# runtime de la app, agregaría ~50 MB al bundle innecesariamente.
documentacion_eph/

# Backlog (markdown, no parte de la app)
BACKLOG.md

# Sandbox de prototipos exploratorios (issues de idea, viz preliminares, etc.)
# No se despliega: los scripts de pruebas/ corren localmente y guardan
# outputs en pruebas/<nombre>/output/.
pruebas/
